<?xml version="1.0" encoding="utf-8"?>
<!--
  Ghost — macOS installer distribution (productbuild).

  Single-component distribution: Ghost.pkg is the one and only payload.
  BlackHole 2ch is installed AUTOMATICALLY by Ghost.pkg's postinstall
  script (see installer/macos/scripts/postinstall). Running BlackHole
  inline after Ghost.app is copied avoids the "payload could not be
  loaded" bug we hit when productbuild tried to combine two signed pkgs.
-->
<installer-gui-script minSpecVersion="1">
    <title>Ghost</title>
    <organization>io.github.userjesus</organization>
    <options customize="never" require-scripts="false" hostArchitectures="arm64,x86_64"/>

    <welcome    file="welcome.html"    mime-type="text/html"/>
    <license    file="license.txt"     mime-type="text/plain"/>
    <conclusion file="conclusion.html" mime-type="text/html"/>

    <choices-outline>
        <line choice="ghost.app"/>
    </choices-outline>

    <choice id="ghost.app"
            visible="false"
            title="Ghost"
            description="Ghost + driver de audio BlackHole 2ch (para captura de reunioes)."
            start_enabled="false"
            start_selected="true">
        <pkg-ref id="io.github.userjesus.ghost"/>
    </choice>

    <pkg-ref id="io.github.userjesus.ghost">Ghost.pkg</pkg-ref>
</installer-gui-script>
